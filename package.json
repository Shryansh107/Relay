{
  "name": "vocallabs-outreach-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "outreach": "./dist/src/cli/run.js"
  },
  "scripts": {
    "dev": "tsx src/cli/run.ts",
    "outreach": "tsx src/cli/run.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.16.3",
    "commander": "^14.0.1",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "handlebars": "^4.7.8",
    "pino": "^9.9.5",
    "pino-pretty": "^13.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "prisma": "^6.16.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
